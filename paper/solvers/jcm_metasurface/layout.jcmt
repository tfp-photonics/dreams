DerivativeParameter {
  Name = "x1"
  TreeEntry = Layout3D/Objects/Sphere1/GlobalPosition(1)
}
DerivativeParameter {
  Name = "y1"
  TreeEntry = Layout3D/Objects/Sphere1/GlobalPosition(2)
}
DerivativeParameter {
  Name = "z1"
  TreeEntry = Layout3D/Objects/Sphere1/GlobalPosition(3)
}

DerivativeParameter {
  Name = "r1"
  TreeEntry = Layout3D/Objects/Sphere1/Radius
}

